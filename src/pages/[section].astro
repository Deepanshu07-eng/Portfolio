---
import BaseLayout from "../layouts/BaseLayout.astro";
import App from "../app/App";
import SiteAnalytics from "../app/SiteAnalytics";
import "../styles/index.css";
import profilePictureUrl from "../assets/profilePicture.png?url";

export function getStaticPaths() {
  return [
    { params: { section: "about" } },
    { params: { section: "impact" } },
    { params: { section: "stack" } },
    { params: { section: "experience" } },
    { params: { section: "recommendations" } },
    { params: { section: "projects" } },
    { params: { section: "contact" } },
  ];
}

const { section } = Astro.params;
const canonical = `https://www.ashwingupta.dev/${section}`;

const titles: Record<string, string> = {
  about:           "About - Deepanshu | Data Analyst/ Software Engineer",
  impact:          "Impact - Deepanshu | Data Analyst/ Software Engineer",
  stack:           "Stack - Deepanshu | Data Analyst/ Software Engineer",
  experience:      "Experience - Deepanshu | Data Analyst/ Software Engineer",
  recommendations: "Recommendations - Deepanshu | Data Analyst/ Software Engineer",
  projects:        "Projects & Research - Deepanshu | Data Analyst/ Software Engineer",
  contact:         "Contact - Deepanshu | Data Analyst/ Software Engineer",
};
---

<BaseLayout
  title={titles[section] ?? "Deepanshu | Data Analyst/ Software Engineer"}
  description="Inference routing. Concurrency architecture. Physics-informed ML. An AI Systems Engineer who thinks in systems and in design - building what surrounds the model, not just the model itself. Bangalore."
  canonical={canonical}
>
  <link slot="head" rel="preload" as="image" href={profilePictureUrl} fetchpriority="high" type="image/webp" />
  <App client:idle />
  <SiteAnalytics client:idle />
</BaseLayout>
